<Window x:Class="SmartPOS.UI.DatabaseConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Database Configuration" Height="500" Width="650"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#3498DB" Padding="15" Margin="0,0,0,20" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="🗄️ Database Configuration" 
                          FontSize="20" 
                          FontWeight="Bold" 
                          Foreground="White"
                          HorizontalAlignment="Center"/>
                <TextBlock Text="Configure your database connection settings" 
                          FontSize="12" 
                          Foreground="#ECF0F1"
                          HorizontalAlignment="Center"
                          Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Configuration Options -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Connection Type -->
                <GroupBox Header="Database Type" Margin="0,10" Padding="10">
                    <StackPanel>
                        <RadioButton x:Name="LocalDBRadio" Content="SQL Server LocalDB (Recommended)" 
                                   IsChecked="True" Margin="5" FontWeight="Bold" Foreground="#27AE60"/>
                        <TextBlock Text="• Easy setup, no installation required" Margin="25,0,0,5" FontSize="11" Foreground="#7F8C8D"/>
                        <TextBlock Text="• Perfect for development and testing" Margin="25,0,0,10" FontSize="11" Foreground="#7F8C8D"/>
                        
                        <RadioButton x:Name="SqlServerRadio" Content="SQL Server (Full Installation)" 
                                   Margin="5" FontWeight="Bold"/>
                        <TextBlock Text="• Requires SQL Server installation" Margin="25,0,0,5" FontSize="11" Foreground="#7F8C8D"/>
                        <TextBlock Text="• Better for production environments" Margin="25,0,0,10" FontSize="11" Foreground="#7F8C8D"/>
                        
                        <RadioButton x:Name="CustomRadio" Content="Custom Connection String" 
                                   Margin="5" FontWeight="Bold"/>
                        <TextBlock Text="• Advanced users only" Margin="25,0,0,5" FontSize="11" Foreground="#E67E22"/>
                    </StackPanel>
                </GroupBox>

                <!-- SQL Server Configuration -->
                <GroupBox x:Name="SqlServerGroup" Header="SQL Server Settings" Margin="0,10" Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Server:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                        <TextBox x:Name="ServerTextBox" Text="localhost" Grid.Row="0" Grid.Column="1" Margin="5" Height="25"/>

                        <TextBlock Text="Database:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                        <TextBox x:Name="DatabaseTextBox" Text="SmartPOS" Grid.Row="1" Grid.Column="1" Margin="5" Height="25"/>

                        <CheckBox x:Name="WindowsAuthCheckBox" Content="Use Windows Authentication" 
                                Grid.Row="2" Grid.Column="1" Margin="5" IsChecked="True"/>

                        <TextBlock x:Name="UsernameLabel" Text="Username:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                        <TextBox x:Name="UsernameTextBox" Grid.Row="3" Grid.Column="1" Margin="5" Height="25" IsEnabled="False"/>

                        <TextBlock x:Name="PasswordLabel" Text="Password:" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                        <PasswordBox x:Name="PasswordBox" Grid.Row="4" Grid.Column="1" Margin="5" Height="25" IsEnabled="False"/>
                    </Grid>
                </GroupBox>

                <!-- Custom Connection String -->
                <GroupBox x:Name="CustomGroup" Header="Custom Connection String" Margin="0,10" Padding="10" Visibility="Collapsed">
                    <StackPanel>
                        <TextBox x:Name="CustomConnectionTextBox" 
                               Height="60" 
                               TextWrapping="Wrap" 
                               AcceptsReturn="True"
                               Margin="5"/>
                        <TextBlock Text="Enter your complete connection string above" 
                                 FontSize="11" 
                                 Foreground="#7F8C8D" 
                                 Margin="5,0"/>
                    </StackPanel>
                </GroupBox>

                <!-- Connection Preview -->
                <GroupBox Header="Connection String Preview" Margin="0,10" Padding="10">
                    <TextBox x:Name="PreviewTextBox" 
                           Height="50" 
                           IsReadOnly="True" 
                           Background="#ECF0F1"
                           TextWrapping="Wrap"/>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Test Connection" 
                    Click="TestConnection_Click"
                    Width="120" 
                    Height="35" 
                    Margin="5"
                    Background="#3498DB"
                    Foreground="White"
                    FontSize="12"/>
            <Button Content="Save and Apply" 
                    Click="SaveAndApply_Click"
                    Width="120" 
                    Height="35" 
                    Margin="5"
                    Background="#27AE60"
                    Foreground="White"
                    FontSize="12"/>
            <Button Content="Cancel" 
                    Click="Cancel_Click"
                    Width="80" 
                    Height="35" 
                    Margin="5"
                    Background="#95A5A6"
                    Foreground="White"
                    FontSize="12"/>
        </StackPanel>
    </Grid>
</Window>