<Window x:Class="SmartPOS.UI.DatabaseProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Database Setup Progress" Height="250" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="Transparent">
    <Border Background="White" BorderBrush="#3498DB" BorderThickness="2" CornerRadius="10">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="🗄️ Database Setup" 
                          FontSize="20" 
                          FontWeight="Bold"
                          Foreground="#3498DB"
                          HorizontalAlignment="Center"/>
                <TextBlock Text="Setting up your Smart POS database..." 
                          FontSize="12" 
                          Foreground="#7F8C8D"
                          HorizontalAlignment="Center"
                          Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Progress Area -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <TextBlock x:Name="ProgressText" 
                          Text="Initializing..." 
                          FontSize="14"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,15"/>
                
                <ProgressBar x:Name="ProgressBar" 
                           Height="20" 
                           Minimum="0" 
                           Maximum="100" 
                           Value="0"
                           Margin="0,0,0,10"/>
                
                <TextBlock x:Name="PercentageText" 
                          Text="0%" 
                          FontSize="12"
                          HorizontalAlignment="Center"
                          Foreground="#3498DB"/>
            </StackPanel>

            <!-- Animation -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <TextBlock x:Name="Dot1" Text="●" Foreground="#3498DB" FontSize="16" Margin="2">
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <ColorAnimation Storyboard.TargetProperty="Foreground.Color" 
                                                  From="#3498DB" To="#ECF0F1" Duration="0:0:0.5" 
                                                  AutoReverse="True"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>
                <TextBlock x:Name="Dot2" Text="●" Foreground="#3498DB" FontSize="16" Margin="2">
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <ColorAnimation Storyboard.TargetProperty="Foreground.Color" 
                                                  From="#3498DB" To="#ECF0F1" Duration="0:0:0.5" 
                                                  BeginTime="0:0:0.2"
                                                  AutoReverse="True"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>
                <TextBlock x:Name="Dot3" Text="●" Foreground="#3498DB" FontSize="16" Margin="2">
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <ColorAnimation Storyboard.TargetProperty="Foreground.Color" 
                                                  From="#3498DB" To="#ECF0F1" Duration="0:0:0.5" 
                                                  BeginTime="0:0:0.4"
                                                  AutoReverse="True"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Border>
</Window>