<Window x:Class="SmartPOS.UI.UserManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:SmartPOS.UI.Converters"
        mc:Ignorable="d"
        Title="User Management" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#FFFFFF">
    
    <Window.Resources>
        <!-- Converters -->
        <converters:BoolToStatusColorConverter x:Key="BoolToStatusColorConverter"/>
        <converters:BoolToStatusTextConverter x:Key="BoolToStatusTextConverter"/>
        <converters:BoolToToggleButtonConverter x:Key="BoolToToggleButtonConverter"/>
        <converters:BoolToToggleColorConverter x:Key="BoolToToggleColorConverter"/>
        
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        
        <Style TargetType="TextBox" x:Key="FormTextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        
        <Style TargetType="ComboBox" x:Key="FormComboBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>
    
    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="20">
            <StackPanel>
                <TextBlock Text="👥 User Management" 
                          FontSize="24" 
                          FontWeight="Bold" 
                          Foreground="White"
                          HorizontalAlignment="Center"/>
                <TextBlock Text="Manage system users and their roles" 
                          FontSize="12" 
                          Foreground="#ECF0F1"
                          HorizontalAlignment="Center"
                          Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- User List -->
            <Border Grid.Column="0" Background="White" Padding="15" CornerRadius="5" BorderBrush="#E9ECEF" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Search and Add -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBox x:Name="SearchTextBox" 
                                Width="200" 
                                Height="35"
                                Padding="8"
                                BorderBrush="#BDC3C7"
                                BorderThickness="1"
                                TextChanged="SearchTextBox_TextChanged"/>
                        <TextBlock Text="🔍" 
                                  VerticalAlignment="Center" 
                                  FontSize="14" 
                                  Margin="-25,0,25,0"/>
                        
                        <Button Content="➕ Add User" 
                               Click="AddUser_Click"
                               Background="#27AE60" 
                               Foreground="White"
                               Style="{StaticResource ActionButton}"
                               Width="100"/>
                    </StackPanel>
                    
                    <!-- Column Headers -->
                    <Grid Grid.Row="1" Background="#F8F9FA" Margin="5,0,5,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="Username" FontWeight="Bold" Padding="5"/>
                        <TextBlock Grid.Column="1" Text="Full Name" FontWeight="Bold" Padding="5"/>
                        <TextBlock Grid.Column="2" Text="Role" FontWeight="Bold" Padding="5"/>
                        <TextBlock Grid.Column="3" Text="Status" FontWeight="Bold" Padding="5"/>
                        <TextBlock Grid.Column="4" Text="Last Login" FontWeight="Bold" Padding="5"/>
                        <TextBlock Grid.Column="5" Text="Actions" FontWeight="Bold" Padding="5" HorizontalAlignment="Center"/>
                    </Grid>
                    
                    <!-- User List -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="UsersItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E9ECEF" BorderThickness="0,0,0,1" Padding="5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Grid.Column="0" Text="{Binding Username}" Padding="5" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding FullName}" Padding="5" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Role.Name}" Padding="5" VerticalAlignment="Center"/>
                                            <Border Grid.Column="3" 
                                                   Background="{Binding IsActive, Converter={StaticResource BoolToStatusColorConverter}}" 
                                                   CornerRadius="10" 
                                                   Padding="8,2" 
                                                   Margin="5">
                                                <TextBlock Text="{Binding IsActive, Converter={StaticResource BoolToStatusTextConverter}}" 
                                                          Foreground="White" 
                                                          FontSize="10" 
                                                          FontWeight="Bold"/>
                                            </Border>
                                            <TextBlock Grid.Column="4" 
                                                      Text="{Binding LastLoginAt, StringFormat='{}{0:MM/dd HH:mm}', TargetNullValue='Never'}" 
                                                      Padding="5" 
                                                      VerticalAlignment="Center"
                                                      FontSize="10"/>
                                            
                                            <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Content="✏️" 
                                                       Click="EditUser_Click" 
                                                       Tag="{Binding Id}"
                                                       Background="#F39C12" 
                                                       Foreground="White"
                                                       Width="25" 
                                                       Height="25" 
                                                       FontSize="10"
                                                       BorderThickness="0"
                                                       Margin="1"
                                                       ToolTip="Edit User"/>
                                                
                                                <Button Content="{Binding IsActive, Converter={StaticResource BoolToToggleButtonConverter}}" 
                                                       Click="ToggleStatus_Click" 
                                                       Tag="{Binding Id}"
                                                       Background="{Binding IsActive, Converter={StaticResource BoolToToggleColorConverter}}" 
                                                       Foreground="White"
                                                       Width="25" 
                                                       Height="25" 
                                                       FontSize="10"
                                                       BorderThickness="0"
                                                       Margin="1"
                                                       ToolTip="Toggle Status"/>
                                                
                                                <Button Content="🔑" 
                                                       Click="ResetPassword_Click" 
                                                       Tag="{Binding Id}"
                                                       Background="#E74C3C" 
                                                       Foreground="White"
                                                       Width="25" 
                                                       Height="25" 
                                                       FontSize="10"
                                                       BorderThickness="0"
                                                       Margin="1"
                                                       ToolTip="Reset Password"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
            
            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="5" Background="#E9ECEF" VerticalAlignment="Stretch"/>
            
            <!-- User Form -->
            <Border Grid.Column="2" Background="White" Padding="15" CornerRadius="5" BorderBrush="#E9ECEF" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="UserFormPanel">
                        <TextBlock Text="➕ Add New User" 
                                  x:Name="FormTitle"
                                  FontSize="18" 
                                  FontWeight="Bold" 
                                  Foreground="#2C3E50" 
                                  Margin="0,0,0,20"/>
                        
                        <!-- Username -->
                        <TextBlock Text="Username *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="UsernameFormTextBox" Style="{StaticResource FormTextBox}" Margin="0,0,0,15"/>
                        
                        <!-- Full Name -->
                        <TextBlock Text="Full Name *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="FullNameFormTextBox" Style="{StaticResource FormTextBox}" Margin="0,0,0,15"/>
                        
                        <!-- Email -->
                        <TextBlock Text="Email" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="EmailFormTextBox" Style="{StaticResource FormTextBox}" Margin="0,0,0,15"/>
                        
                        <!-- Phone -->
                        <TextBlock Text="Phone" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="PhoneFormTextBox" Style="{StaticResource FormTextBox}" Margin="0,0,0,15"/>
                        
                        <!-- Role -->
                        <TextBlock Text="Role *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="RoleFormComboBox" 
                                 Style="{StaticResource FormComboBox}"
                                 DisplayMemberPath="Name"
                                 SelectedValuePath="Id"
                                 Margin="0,0,0,15"/>
                        
                        <!-- Password (for new users only) -->
                        <StackPanel x:Name="PasswordPanel">
                            <TextBlock Text="Password *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <PasswordBox x:Name="PasswordFormBox" 
                                        Height="35" 
                                        Padding="8" 
                                        FontSize="12"
                                        BorderBrush="#BDC3C7"
                                        BorderThickness="1"
                                        Margin="0,0,0,5"/>
                            
                            <TextBlock Text="Confirm Password *" FontWeight="SemiBold" Margin="0,10,0,5"/>
                            <PasswordBox x:Name="ConfirmPasswordFormBox" 
                                        Height="35" 
                                        Padding="8" 
                                        FontSize="12"
                                        BorderBrush="#BDC3C7"
                                        BorderThickness="1"
                                        Margin="0,0,0,15"/>
                        </StackPanel>
                        
                        <!-- Active Status -->
                        <CheckBox x:Name="IsActiveFormCheckBox" 
                                 Content="Active User" 
                                 IsChecked="True" 
                                 Margin="0,0,0,20"/>
                        
                        <!-- Action Buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="SaveFormButton"
                                   Content="💾 Save User" 
                                   Click="SaveUser_Click"
                                   Background="#27AE60" 
                                   Foreground="White"
                                   Style="{StaticResource ActionButton}"
                                   Width="100"
                                   Margin="0,0,10,0"/>
                            
                            <Button Content="🚫 Cancel" 
                                   Click="CancelForm_Click"
                                   Background="#95A5A6" 
                                   Foreground="White"
                                   Style="{StaticResource ActionButton}"
                                   Width="80"/>
                        </StackPanel>
                        
                        <!-- Hidden field to store user ID for editing -->
                        <TextBox x:Name="UserIdFormTextBox" Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>