<Window x:Class="SmartPOS.UI.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Change Password" Height="400" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFFFFF">
    
    <Window.Resources>
        <Style TargetType="PasswordBox" x:Key="FormPasswordBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>
    
    <Grid Background="#F8F9FA">
        <!-- Main Panel -->
        <Border Background="White" 
                Margin="30" 
                Padding="30"
                CornerRadius="10"
                BorderBrush="#E9ECEF" 
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="Gray" Direction="270" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            
            <StackPanel>
                <!-- Header -->
                <TextBlock Text="🔑" 
                          FontSize="32" 
                          HorizontalAlignment="Center" 
                          Margin="0,0,0,10"/>
                
                <TextBlock Text="Change Password" 
                          FontSize="20" 
                          FontWeight="Bold" 
                          HorizontalAlignment="Center"
                          Foreground="#2C3E50" 
                          Margin="0,0,0,5"/>
                
                <TextBlock x:Name="UserInfoText"
                          Text="User: Admin" 
                          FontSize="12" 
                          HorizontalAlignment="Center"
                          Foreground="#7F8C8D" 
                          Margin="0,0,0,30"/>
                
                <!-- Current Password -->
                <TextBlock Text="Current Password" 
                          FontSize="14" 
                          FontWeight="SemiBold" 
                          Foreground="#2C3E50" 
                          Margin="0,0,0,5"/>
                <PasswordBox x:Name="CurrentPasswordBox" 
                            Style="{StaticResource FormPasswordBox}"
                            Margin="0,0,0,15"/>
                
                <!-- New Password -->
                <TextBlock Text="New Password" 
                          FontSize="14" 
                          FontWeight="SemiBold" 
                          Foreground="#2C3E50" 
                          Margin="0,0,0,5"/>
                <PasswordBox x:Name="NewPasswordBox" 
                            Style="{StaticResource FormPasswordBox}"
                            Margin="0,0,0,15"/>
                
                <!-- Confirm New Password -->
                <TextBlock Text="Confirm New Password" 
                          FontSize="14" 
                          FontWeight="SemiBold" 
                          Foreground="#2C3E50" 
                          Margin="0,0,0,5"/>
                <PasswordBox x:Name="ConfirmPasswordBox" 
                            Style="{StaticResource FormPasswordBox}"
                            Margin="0,0,0,20"/>
                
                <!-- Password Requirements -->
                <Border Background="#F8F9FA" 
                        Padding="10" 
                        CornerRadius="5"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Password Requirements:" 
                                  FontSize="12" 
                                  FontWeight="SemiBold"
                                  Foreground="#6C757D" 
                                  Margin="0,0,0,5"/>
                        
                        <TextBlock Text="• At least 6 characters long" 
                                  FontSize="11"
                                  Foreground="#6C757D" />
                        <TextBlock Text="• Different from current password" 
                                  FontSize="11"
                                  Foreground="#6C757D" />
                        <TextBlock Text="• Passwords must match" 
                                  FontSize="11"
                                  Foreground="#6C757D" />
                    </StackPanel>
                </Border>
                
                <!-- Status Message -->
                <TextBlock x:Name="StatusMessage" 
                          Text="" 
                          FontSize="12"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,15"
                          Visibility="Collapsed"/>
                
                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="💾 Change Password" 
                           Click="ChangePassword_Click"
                           Background="#27AE60" 
                           Foreground="White"
                           Style="{StaticResource ActionButton}"
                           Width="150"/>
                    
                    <Button Content="❌ Cancel" 
                           Click="Cancel_Click"
                           Background="#95A5A6" 
                           Foreground="White"
                           Style="{StaticResource ActionButton}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>