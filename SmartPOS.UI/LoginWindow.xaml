<Window x:Class="SmartPOS.UI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Smart POS - Login" Height="500" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFFFFF"
        WindowStyle="SingleBorderWindow">
    
    <Window.Resources>
        <!-- Define styles for modern UI -->
        <Style TargetType="TextBox" x:Key="ModernTextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
        </Style>
        
        <Style TargetType="PasswordBox" x:Key="ModernPasswordBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
        </Style>
        
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5"
                                Padding="5">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2980B9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#21618C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Main Login Panel -->
        <Border Grid.Row="0" 
                Background="White" 
                Margin="30" 
                Padding="40"
                CornerRadius="10"
                BorderBrush="#E9ECEF" 
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="Gray" Direction="270" ShadowDepth="3" Opacity="0.2"/>
            </Border.Effect>
            
            <StackPanel VerticalAlignment="Center">
                <!-- Header -->
                <TextBlock Text="🔐" 
                          FontSize="48" 
                          HorizontalAlignment="Center" 
                          Margin="0,0,0,10"/>
                
                <TextBlock Text="Smart POS Login" 
                          FontSize="24" 
                          FontWeight="Bold" 
                          HorizontalAlignment="Center"
                          Foreground="#2C3E50" 
                          Margin="0,0,0,5"/>
                
                <TextBlock Text="Enter your credentials to access the system" 
                          FontSize="12" 
                          HorizontalAlignment="Center"
                          Foreground="#7F8C8D" 
                          Margin="0,0,0,30"/>
                
                <!-- Username Input -->
                <TextBlock Text="Username" 
                          FontSize="14" 
                          FontWeight="SemiBold" 
                          Foreground="#2C3E50" 
                          Margin="0,0,0,5"/>
                <TextBox x:Name="UsernameTextBox" 
                        Style="{StaticResource ModernTextBox}"
                        Margin="0,0,0,15"/>
                
                <!-- Password Input -->
                <TextBlock Text="Password" 
                          FontSize="14" 
                          FontWeight="SemiBold" 
                          Foreground="#2C3E50" 
                          Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox" 
                            Style="{StaticResource ModernPasswordBox}"
                            Margin="0,0,0,15"/>
                
                <!-- Remember Me -->
                <CheckBox x:Name="RememberMeCheckBox" 
                         Content="Remember me" 
                         FontSize="12"
                         Foreground="#7F8C8D"
                         Margin="0,0,0,20"/>
                
                <!-- Login Button -->
                <Button x:Name="LoginButton"
                       Content="LOGIN" 
                       Style="{StaticResource PrimaryButton}"
                       Click="Login_Click"
                       Margin="0,0,0,15"/>
                
                <!-- Status Message -->
                <TextBlock x:Name="StatusMessage" 
                          Text="" 
                          FontSize="12"
                          HorizontalAlignment="Center"
                          Margin="0,10,0,0"
                          Visibility="Collapsed"/>
                
                <!-- Quick Access Users -->
                <Border Background="#F8F9FA" 
                        Padding="10" 
                        CornerRadius="5"
                        Margin="0,20,0,0">
                    <StackPanel>
                        <TextBlock Text="Quick Access (Development)" 
                                  FontSize="11" 
                                  FontWeight="SemiBold"
                                  Foreground="#6C757D" 
                                  HorizontalAlignment="Center"
                                  Margin="0,0,0,8"/>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="Admin" 
                                   Click="QuickLogin_Click" 
                                   Tag="admin"
                                   Width="60" 
                                   Height="25" 
                                   FontSize="10"
                                   Background="#E74C3C" 
                                   Foreground="White"
                                   BorderThickness="0"
                                   Margin="2"/>
                            
                            <Button Content="Manager" 
                                   Click="QuickLogin_Click" 
                                   Tag="manager"
                                   Width="60" 
                                   Height="25" 
                                   FontSize="10"
                                   Background="#F39C12" 
                                   Foreground="White"
                                   BorderThickness="0"
                                   Margin="2"/>
                            
                            <Button Content="Cashier" 
                                   Click="QuickLogin_Click" 
                                   Tag="cashier"
                                   Width="60" 
                                   Height="25" 
                                   FontSize="10"
                                   Background="#27AE60" 
                                   Foreground="White"
                                   BorderThickness="0"
                                   Margin="2"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
        
        <!-- Footer -->
        <TextBlock Grid.Row="1" 
                  Text="Smart Retail POS Management System v1.0.0" 
                  FontSize="10" 
                  HorizontalAlignment="Center"
                  Foreground="#ADB5BD" 
                  Margin="0,0,0,10"/>
    </Grid>
</Window>