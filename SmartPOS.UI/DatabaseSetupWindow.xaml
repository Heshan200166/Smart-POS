<Window x:Class="SmartPOS.UI.DatabaseSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Smart POS - Database Setup &amp; Initialization" Height="480" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F8F9FA">
    
    <Window.Resources>
        <Style TargetType="Button" x:Key="SetupButton">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <TextBlock Text="🗄️ Database Setup &amp; Verification" 
                       FontSize="22" 
                       FontWeight="Bold" 
                       Foreground="#2C3E50" 
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Configure and initialize your system database to get started." 
                       FontSize="13" 
                       Foreground="#7F8C8D" 
                       HorizontalAlignment="Center" 
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Main Status Area -->
        <Border Grid.Row="1" Background="White" Padding="25" CornerRadius="8" BorderBrush="#E9ECEF" BorderThickness="1">
            <StackPanel VerticalAlignment="Center">
                <!-- Current Config Summary -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Database Provider:" FontWeight="SemiBold" Foreground="#34495E" FontSize="13" Margin="5"/>
                    <TextBlock x:Name="ProviderText" Text="Loading..." Foreground="#2C3E50" FontSize="13" Grid.Column="1" Margin="5"/>

                    <TextBlock Text="Connection String:" Grid.Row="1" FontWeight="SemiBold" Foreground="#34495E" FontSize="13" Margin="5"/>
                    <TextBlock x:Name="ConnectionStringText" Text="Loading..." Foreground="#7F8C8D" FontSize="12" Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" Margin="5"/>
                </Grid>

                <Separator Margin="0,0,0,20" Background="#F1F3F5"/>

                <!-- Status Indicators -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                    <TextBlock x:Name="DbStatusIcon" Text="⏳" FontSize="20" Margin="0,0,10,0"/>
                    <TextBlock x:Name="DbStatusText" Text="Testing database connection..." FontSize="15" FontWeight="SemiBold" Foreground="#E67E22" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Content="⚙️ Configure Connection" 
                            Click="ConfigureDatabase_Click" 
                            Width="180" 
                            Background="#E67E22" 
                            Style="{StaticResource SetupButton}" 
                            Margin="5"/>

                    <Button Content="🔄 Test Connection" 
                            Click="TestConnection_Click" 
                            Width="150" 
                            Background="#3498DB" 
                            Style="{StaticResource SetupButton}" 
                            Margin="5"/>

                    <Button Content="🚀 Initialize Database" 
                            Click="InitializeDatabase_Click" 
                            Width="160" 
                            Background="#27AE60" 
                            Style="{StaticResource SetupButton}" 
                            Margin="5"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Footer / Flow Actions -->
        <StackPanel Grid.Row="2" Margin="0,20,0,0">
            <Button x:Name="ProceedToLoginButton" 
                    Content="Continue to Login ➔" 
                    Click="ProceedToLogin_Click" 
                    Height="45" 
                    Background="#95A5A6" 
                    IsEnabled="False"
                    Style="{StaticResource SetupButton}"/>
            
            <TextBlock x:Name="SetupInstructions" 
                       Text="⚠️ Please initialize the database before continuing." 
                       Foreground="#E74C3C" 
                       FontSize="11" 
                       HorizontalAlignment="Center" 
                       Margin="0,8,0,0"/>
        </StackPanel>
    </Grid>
</Window>
