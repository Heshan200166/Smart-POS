<Window x:Class="SmartPOS.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SmartPOS.UI"
        mc:Ignorable="d"
        Title="Smart Retail POS Management System" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#FFFFFF"
        Foreground="#000000">
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="20">
            <StackPanel>
                <TextBlock Text="Smart Retail POS Management System" 
                          FontSize="24" 
                          FontWeight="Bold" 
                          Foreground="White"
                          HorizontalAlignment="Center"/>
                <TextBlock Text="Version 1.0.0 - Phase 1: Project Foundation" 
                          FontSize="12" 
                          Foreground="#ECF0F1"
                          HorizontalAlignment="Center"
                          Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Margin="20" VerticalScrollBarVisibility="Auto">
            <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center">
                <TextBlock Text="🚀 System Status" 
                          FontSize="20" 
                          FontWeight="Bold"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,20"
                          Foreground="#2C3E50"/>
                
                <StackPanel Orientation="Horizontal" Margin="0,10">
                    <TextBlock Text="✓ " Foreground="Green" FontSize="16" FontWeight="Bold" Width="30"/>
                    <TextBlock Text="Application Initialized Successfully" FontSize="14" Foreground="#27AE60"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Margin="0,10">
                    <TextBlock Text="✓ " Foreground="Green" FontSize="16" FontWeight="Bold" Width="30"/>
                    <TextBlock Text="Dependency Injection Configured" FontSize="14" Foreground="#27AE60"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Margin="0,10">
                    <TextBlock Text="✓ " Foreground="Green" FontSize="16" FontWeight="Bold" Width="30"/>
                    <TextBlock Text="Logging System Active" FontSize="14" Foreground="#27AE60"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Margin="0,10">
                    <TextBlock x:Name="DbStatusIcon" Text="⏳ " Foreground="Orange" FontSize="16" FontWeight="Bold" Width="30"/>
                    <TextBlock x:Name="DbStatusText" Text="Database Connection Pending" FontSize="14" Foreground="#E67E22"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,30,0,0" HorizontalAlignment="Center">
                    <Button Content="Test Database Connection" 
                           Click="TestConnection_Click"
                           Width="220" 
                           Height="40" 
                           Margin="5,0"
                           Background="#3498DB"
                           Foreground="White"
                           FontSize="14"
                           Cursor="Hand"/>

                    <Button Content="Initialize Database" 
                           Click="InitializeDatabase_Click"
                           Width="220" 
                           Height="40" 
                           Margin="5,0"
                           Background="#27AE60"
                           Foreground="White"
                           FontSize="14"
                           Cursor="Hand"/>
                </StackPanel>

                <TextBlock Text="Phase 1 Foundation Complete ✅" 
                          FontSize="14"
                          HorizontalAlignment="Center"
                          Margin="0,40,0,0"
                          Foreground="#7F8C8D"/>
                
                <TextBlock Text="Ready to Test Database Connection" 
                          FontSize="12"
                          HorizontalAlignment="Center"
                          Margin="0,5,0,0"
                          Foreground="#95A5A6"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#ECF0F1" Padding="10" BorderThickness="0,1,0,0" BorderBrush="#BDC3C7">
            <TextBlock x:Name="StatusText" 
                      Text="Ready" 
                      HorizontalAlignment="Center"
                      Foreground="#34495E"
                      FontSize="12"/>
        </Border>
    </Grid>
</Window>
