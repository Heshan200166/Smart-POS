<Window x:Class="SmartPOS.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SmartPOS.UI"
        mc:Ignorable="d"
        Title="Smart Retail POS Management System" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="20">
            <StackPanel>
                <TextBlock Text="Smart Retail POS Management System" 
                          FontSize="24" 
                          FontWeight="Bold" 
                          Foreground="White"
                          HorizontalAlignment="Center"/>
                <TextBlock Text="Version 1.0.0 - Phase 1: Project Foundation" 
                          FontSize="12" 
                          Foreground="#ECF0F1"
                          HorizontalAlignment="Center"
                          Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" Margin="20">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🚀 System Status" 
                          FontSize="20" 
                          FontWeight="Bold"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,20"/>
                
                <StackPanel Orientation="Horizontal" Margin="0,10">
                    <TextBlock Text="✓ " Foreground="Green" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="Application Initialized" FontSize="14"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Margin="0,10">
                    <TextBlock Text="✓ " Foreground="Green" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="Dependency Injection Configured" FontSize="14"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Margin="0,10">
                    <TextBlock Text="✓ " Foreground="Green" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="Logging System Active" FontSize="14"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Margin="0,10">
                    <TextBlock x:Name="DbStatusIcon" Text="⏳ " Foreground="Orange" FontSize="16" FontWeight="Bold"/>
                    <TextBlock x:Name="DbStatusText" Text="Database Connection Pending" FontSize="14"/>
                </StackPanel>

                <Button Content="Test Database Connection" 
                       Click="TestConnection_Click"
                       Width="200" 
                       Height="35" 
                       Margin="0,30,0,0"
                       Background="#3498DB"
                       Foreground="White"
                       FontSize="14"
                       Cursor="Hand"/>

                <Button Content="Initialize Database" 
                       Click="InitializeDatabase_Click"
                       Width="200" 
                       Height="35" 
                       Margin="0,10,0,0"
                       Background="#27AE60"
                       Foreground="White"
                       FontSize="14"
                       Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#ECF0F1" Padding="10">
            <TextBlock x:Name="StatusText" 
                      Text="Ready" 
                      HorizontalAlignment="Center"
                      Foreground="#7F8C8D"/>
        </Border>
    </Grid>
</Window>
