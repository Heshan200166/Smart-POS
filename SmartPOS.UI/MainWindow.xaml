<Window x:Class="SmartPOS.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SmartPOS.UI"
        mc:Ignorable="d"
        Title="Smart Retail POS Management System" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#FFFFFF"
        Foreground="#000000">
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="20">
            <StackPanel>
                <TextBlock Text="Smart Retail POS Management System" 
                          FontSize="24" 
                          FontWeight="Bold" 
                          Foreground="White"
                          HorizontalAlignment="Center"/>
                <TextBlock Text="Version 1.0.0 - Phase 2: User Authentication" 
                          FontSize="12" 
                          Foreground="#ECF0F1"
                          HorizontalAlignment="Center"
                          Margin="0,5,0,0"/>
                
                <!-- User Info -->
                <StackPanel Orientation="Horizontal" 
                           HorizontalAlignment="Right" 
                           VerticalAlignment="Top"
                           Margin="0,-40,0,0">
                    <TextBlock x:Name="CurrentUserText"
                              Text="👤 Not logged in" 
                              FontSize="12" 
                              Foreground="#ECF0F1"
                              VerticalAlignment="Center"
                              Margin="0,0,10,0"/>
                    
                    <Button x:Name="LogoutButton"
                           Content="🚪 Logout"
                           Click="Logout_Click"
                           Background="#E74C3C"
                           Foreground="White"
                           BorderThickness="0"
                           Padding="8,4"
                           FontSize="11"
                           Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Margin="20" VerticalScrollBarVisibility="Auto">
            <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center">
                <TextBlock Text="🚀 System Status" 
                          FontSize="20" 
                          FontWeight="Bold"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,20"
                          Foreground="#2C3E50"/>
                
                <StackPanel Orientation="Horizontal" Margin="0,10">
                    <TextBlock Text="✓ " Foreground="Green" FontSize="16" FontWeight="Bold" Width="30"/>
                    <TextBlock Text="Application Initialized Successfully" FontSize="14" Foreground="#27AE60"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Margin="0,10">
                    <TextBlock Text="✓ " Foreground="Green" FontSize="16" FontWeight="Bold" Width="30"/>
                    <TextBlock Text="Dependency Injection Configured" FontSize="14" Foreground="#27AE60"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Margin="0,10">
                    <TextBlock Text="✓ " Foreground="Green" FontSize="16" FontWeight="Bold" Width="30"/>
                    <TextBlock Text="Logging System Active" FontSize="14" Foreground="#27AE60"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Margin="0,10">
                    <TextBlock x:Name="DbStatusIcon" Text="⏳ " Foreground="Orange" FontSize="16" FontWeight="Bold" Width="30"/>
                    <TextBlock x:Name="DbStatusText" Text="Database Connection Pending" FontSize="14" Foreground="#E67E22"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,30,0,0" HorizontalAlignment="Center">
                    <Button Content="Test Database Connection" 
                           Click="TestConnection_Click"
                           Width="200" 
                           Height="40" 
                           Margin="5,0"
                           Background="#3498DB"
                           Foreground="White"
                           FontSize="14"
                           Cursor="Hand"/>

                    <Button Content="Initialize Database" 
                           Click="InitializeDatabase_Click"
                           Width="200" 
                           Height="40" 
                           Margin="5,0"
                           Background="#27AE60"
                           Foreground="White"
                           FontSize="14"
                           Cursor="Hand"/>
                </StackPanel>
                
                <Button Content="⚙️ Configure Database" 
                       Click="ConfigureDatabase_Click"
                       Width="220" 
                       Height="35" 
                       Margin="0,15,0,0"
                       HorizontalAlignment="Center"
                       Background="#E67E22"
                       Foreground="White"
                       FontSize="12"
                       Cursor="Hand"/>

                <!-- User Management Section (Admin Only) -->
                <Border x:Name="AdminPanel" 
                        Background="#FFFFFF" 
                        Padding="15" 
                        CornerRadius="5"
                        BorderBrush="#BDC3C7" 
                        BorderThickness="1"
                        Margin="0,30,0,0"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="👥 Administrative Functions" 
                                  FontSize="16" 
                                  FontWeight="Bold"
                                  HorizontalAlignment="Center"
                                  Margin="0,0,0,15"
                                  Foreground="#2C3E50"/>
                        
                        <Button Content="👥 Manage Users" 
                               Click="ManageUsers_Click"
                               Width="200" 
                               Height="40" 
                               Background="#9B59B6"
                               Foreground="White"
                               FontSize="14"
                               Cursor="Hand"
                               Margin="0,5"/>
                        
                        <Button Content="🔒 Manage Roles" 
                               Click="ManageRoles_Click"
                               Width="200" 
                               Height="40" 
                               Background="#8E44AD"
                               Foreground="White"
                               FontSize="14"
                               Cursor="Hand"
                               Margin="0,5"/>
                        
                        <Button Content="🔑 Change Password" 
                               Click="ChangePassword_Click"
                               Width="200" 
                               Height="40" 
                               Background="#34495E"
                               Foreground="White"
                               FontSize="14"
                               Cursor="Hand"
                               Margin="0,5"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Phase 2 Authentication Complete ✅" 
                          FontSize="14"
                          HorizontalAlignment="Center"
                          Margin="0,40,0,0"
                          Foreground="#7F8C8D"/>
                
                <TextBlock Text="User authentication and role-based access implemented" 
                          FontSize="12"
                          HorizontalAlignment="Center"
                          Margin="0,5,0,0"
                          Foreground="#95A5A6"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#ECF0F1" Padding="10" BorderThickness="0,1,0,0" BorderBrush="#BDC3C7">
            <TextBlock x:Name="StatusText" 
                      Text="Ready" 
                      HorizontalAlignment="Center"
                      Foreground="#34495E"
                      FontSize="12"/>
        </Border>
    </Grid>
</Window>
